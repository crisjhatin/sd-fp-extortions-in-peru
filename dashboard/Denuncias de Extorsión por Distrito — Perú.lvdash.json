{
  "datasets": [
    {
      "name": "ac43af72",
      "displayName": "extortion_reports",
      "config": {
        "version": "1.1",
        "source": "catalog_cr.golden.extortion_reports",
        "dimensions": [
          {
            "name": "report_id",
            "expr": "source.report_id",
            "displayName": "Report Id"
          },
          {
            "name": "ubigeo",
            "expr": "source.ubigeo",
            "displayName": "Ubigeo"
          },
          {
            "name": "department",
            "expr": "source.department",
            "displayName": "Department"
          },
          {
            "name": "province",
            "expr": "source.province",
            "displayName": "Province"
          },
          {
            "name": "district",
            "expr": "source.district",
            "displayName": "District"
          },
          {
            "name": "total_extortions",
            "expr": "source.total_extortions",
            "displayName": "Total Extortions"
          },
          {
            "name": "min_extortions",
            "expr": "source.min_extortions",
            "displayName": "Min Extortions"
          },
          {
            "name": "max_extortions",
            "expr": "source.max_extortions",
            "displayName": "Max Extortions"
          },
          {
            "name": "year_min_extortions",
            "expr": "source.year_min_extortions",
            "displayName": "Year Min Extortions"
          },
          {
            "name": "year_max_extortions",
            "expr": "source.year_max_extortions",
            "displayName": "Year Max Extortions"
          },
          {
            "name": "avg_extortions",
            "expr": "source.avg_extortions",
            "displayName": "Avg Extortions"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          },
          {
            "displayName": "Total Denuncias",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              },
              "abbreviation": "compact"
            },
            "name": "sum_total_extortions",
            "expr": "SUM(total_extortions)",
            "comment": "Suma total de denuncias de extorsion"
          },
          {
            "name": "max_extortions_peak",
            "expr": "MAX(max_extortions)",
            "displayName": "Pico Máximo Anual",
            "comment": "Mayor cantidad de extorsiones en un solo año para un distrito"
          },
          {
            "displayName": "Promedio Extorsiones",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            },
            "name": "avg_extortions_measure",
            "expr": "AVG(avg_extortions)",
            "comment": "Promedio de extorsiones anuales por distrito"
          }
        ]
      }
    },
    {
      "name": "top100_districts",
      "displayName": "Top 25 Distritos",
      "queryLines": [
        "SELECT\n",
        "  department,\n",
        "  province,\n",
        "  district,\n",
        "  total_extortions\n",
        "FROM\n",
        "  catalog_cr.golden.extortion_reports\n",
        "ORDER BY\n",
        "  total_extortions DESC\n",
        "LIMIT 25"
      ]
    }
  ],
